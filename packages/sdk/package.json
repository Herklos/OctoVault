{
  "name": "@drakkar.software/octovault-sdk",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "description": "OctoVault — headless SDK (crypto, sync, WAL/CRDT models, pure domain logic)",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./platform": {
      "react-native": {
        "types": "./dist/platform/index.d.ts",
        "import": "./dist/platform/index.native.js"
      },
      "types": "./dist/platform/index.d.ts",
      "import": "./dist/platform/index.js"
    },
    "./hash-wasm-shim": {
      "types": "./dist/platform/hash-wasm-shim.d.ts",
      "import": "./dist/platform/hash-wasm-shim.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@drakkar.software/starfish-client": "3.0.0-alpha.26",
    "@drakkar.software/starfish-identities": "3.0.0-alpha.26",
    "@drakkar.software/starfish-keyring": "3.0.0-alpha.26",
    "@drakkar.software/starfish-protocol": "3.0.0-alpha.26",
    "@drakkar.software/starfish-sharing": "3.0.0-alpha.26",
    "@drakkar.software/starfish-wal": "3.0.0-alpha.26",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/bip39": "^2.0.0",
    "hash-wasm": "^4.12.0"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "*",
    "expo-secure-store": "*",
    "react-native-quick-crypto": "*"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": { "optional": true },
    "expo-secure-store": { "optional": true },
    "react-native-quick-crypto": { "optional": true }
  },
  "devDependencies": {
    "@octovault/tsconfig": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/node": "^22.19.19",
    "expo-secure-store": "*",
    "react-native-quick-crypto": "^1.1.4",
    "tsup": "^8.3.5",
    "typescript": "~6.0.3",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
