{
  "extends": ["expo/tsconfig.base", "@octovault/tsconfig/base.json"],
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@drakkar.software/octovault-sdk": [
        "../../packages/sdk/src/index.ts"
      ],
      "@drakkar.software/octovault-sdk/platform": [
        "../../packages/sdk/src/platform/index.ts"
      ],
      "@drakkar.software/octovault-sdk/hash-wasm-shim": [
        "../../packages/sdk/src/platform/hash-wasm-shim.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
