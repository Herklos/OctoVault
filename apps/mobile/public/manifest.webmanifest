{
  "id": "/",
  "name": "OctoChat",
  "short_name": "OctoChat",
  "description": "End-to-end-encrypted team chat. Spaces, rooms and threads, sealed per-room — with a marine, octopus-themed interface.",
  "lang": "en",
  "dir": "ltr",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#0b151c",
  "theme_color": "#0b151c",
  "categories": ["social", "communication", "productivity"],
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
