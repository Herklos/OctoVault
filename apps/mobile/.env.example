# Copy this file to apps/mobile/.env for local development.
# The real .env is git-ignored; this template is committed so the dev setup is reproducible.
# All EXPO_PUBLIC_* vars are inlined into the bundle at build time (not secret).

# Base URL of the Starfish sync server the app talks to (REST + SSE).
# Local dev:        http://localhost:8787  (the apps/server dev server — `pnpm dev:server`)
# Physical device:  use this machine's LAN IP, e.g. http://192.168.1.20:8787
# Deployed:         https://<host>/sync  (multi-tenant drakkar-sync; nginx mounts the
#                   sync router under /sync, e.g. https://dev-sync.drakkar.software/sync)
EXPO_PUBLIC_STARFISH_URL=http://localhost:8787

# Path prefix prepended to every SIGNED request path. The SDK signs the endpoint
# path (not the baseUrl), so the namespace must live HERE, not in the URL above.
# Local dev:  empty  (apps/server mounts the sync router at root: /pull, /push, /events)
# Deployed:   /v1/octochat  (OctoChat is the `octochat` namespace on drakkar-sync)
EXPO_PUBLIC_STARFISH_NAMESPACE=

# Optional: override the SSE events endpoint.
# Defaults to ${EXPO_PUBLIC_STARFISH_URL}${EXPO_PUBLIC_STARFISH_PREFIX}/events when unset.
# EXPO_PUBLIC_EVENTS_URL=http://localhost:8787/events
